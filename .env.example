# Copy to `.env` in the repo root when you wire LLM calls (e.g. OpenRouter).
# OPENROUTER_API_KEY=

# parlimen.gov.my session cookie — required for PDF downloads.
# Visit parlimen.gov.my, set language to EN, then copy cookies from browser DevTools → Network.
# PARLIMEN_COOKIE=

# Optional: live parliament CSV+PDF integration test (see tests/test_parliament_live_year_csv_pdf.py).
# Default `pytest` skips it (`-m "not live_parliament"`). Run explicitly:
#   pytest tests/test_parliament_live_year_csv_pdf.py -m live_parliament
# PARLIAMENT_LIVE_CSV_TEST=1
# PARLIAMENT_LIVE_CSV_YEAR=2024
# PARLIAMENT_LIVE_CSV_MAX_NODES=100
